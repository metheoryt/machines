# shellcheck shell=bash
# Loads the flake devShell via nix-direnv on `cd` into the repo.
#
# Why this file exists: the devShell's shellHook installs the git-hooks.nix
# pre-commit hook (.git/hooks/pre-commit), which hard-codes /nix/store paths to
# the pre-commit tooling. Under a bare `nix develop` those paths are only rooted
# while the shell is open, so the weekly `nix-collect-garbage --delete-older-than
# 7d` (modules/system/base.nix) reaps them and the hook breaks until the next
# shell entry. nix-direnv keeps a PERSISTENT GC root under .direnv/, so the
# closure survives GC and the hook keeps working across reboots and weeks.
#
# One-time setup on each machine after checkout: `direnv allow`.
#
# Guarded so a machine with direnv but WITHOUT nix (e.g. a non-Nix platform that
# happens to have direnv) doesn't error on `cd` — `use flake` only fires where
# nix actually exists.
if command -v nix >/dev/null 2>&1; then
  use flake
fi
