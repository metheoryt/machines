# IDE directories
.idea/
.vscode/
*.sublime-*

# Nix build artifacts
result
result-*

# Temporary files
*.tmp
*.bak
*.backup.*

# Configuration backups
.config-backup-*
*.backup

# Development shells
.direnv/

# OS generated files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~

# Log files
*.log

# Flake inputs (managed externally)
nixos-hardware/

# Claude Code per-repo local settings (personal: permission allowlist + gortex
# hooks). Machine-local by convention — keep out of git.
.claude/settings.local.json

# OpenClaude per-repo local state — machine-local, keep out of git
.openclaude/

# Local pre-auth key stash for provision/tailscale-wsl.sh (--authkey-file).
# Reusable Headscale keys are secrets — never commit them.
provision/secrets/

# Gortex daemon per-repo sidecar DB — machine-local index state, never commit.
.gortex/

# Per-host convergence state + runtime root (à la ~/.config). Gitignored so
# converge.sh / provision writes never trip the clean-tree gate. Per-host by
# construction — never synced. See docs/superpowers/specs/2026-07-21-fleet-
# converge-self-healing-sync-design.md §5.
/.machines/

# Per-host WSL self-declaration for the fleet (provision/fleet-local.sh). A host
# declares itself a fleet member locally without a committed fleet.json entry;
# the Windows parent discovers it via `wsl -l`. Per-host, never synced.
fleet.local.json
