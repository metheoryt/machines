# IDE directories
.idea/
.vscode/
*.sublime-*

# Nix build artifacts
result
result-*

# Auto-generated by git-hooks.nix on `nix develop` (contains /nix/store paths).
# The source of truth is the `hooks` block in flake.nix.
.pre-commit-config.yaml

# Temporary files
*.tmp
*.bak
*.backup.*

# Configuration backups
.config-backup-*
*.backup

# Development shells
.direnv/

# OS generated files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~

# Log files
*.log

# Flake inputs (managed externally)
nixos-hardware/

# Claude Code per-repo local settings (personal: permission allowlist + gortex
# hooks). Machine-local by convention — keep out of git.
.claude/settings.local.json

# OpenClaude per-repo local state — machine-local, keep out of git
.openclaude/

# Local pre-auth key stash for provision/tailscale-wsl.sh (--authkey-file).
# Reusable Headscale keys are secrets — never commit them.
provision/secrets/

# Gortex daemon per-repo sidecar DB — machine-local index state, never commit.
.gortex/
